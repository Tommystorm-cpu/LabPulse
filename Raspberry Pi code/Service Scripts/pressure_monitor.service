[Unit]
Description=Runs the Pressure Monitor Script as BKG service
After=network.target

[Service]
ExecStart=/home/monitorpi/pressureenv/bin/python /home/monitorpi/pressurepub.py
WorkingDirectory=/home/monitorpi
Restart=on-failure
RestartSec=5s
User=root
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
